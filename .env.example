# --- Database (PostgreSQL) ---
# Required: Full connection string for Neon, Supabase, Railway, or any PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Application ---
# Production URL (used for canonical links and SEO)
VITE_APP_URL=https://your-domain.com

# API base URL (when frontend and backend are on different domains)
VITE_API_URL=https://your-api-domain.com/api

# Node environment
NODE_ENV=production

# Server port (default: 8080)
PORT=8080

# --- Payment / CCP ---
# CCP account for Baridi Mob payments
# CCP_NUMBER=8339830
# CCP_KEY=57
# CCP_OWNER=بلقاسم محروق الراس

# --- Contact ---
# WhatsApp number (without +)
VITE_WHATSAPP_NUMBER=213556640211

# Developer email
VITE_CONTACT_EMAIL=belkacem.mahrougas@dzlaw.dz

# --- Session / Security ---
# Secret key for session management (use a long random string in production)
SESSION_SECRET=change_this_to_a_very_long_random_string_in_production

# --- Optional: Vercel / Deployment ---
# Vercel project URL (auto-set by Vercel)
# VERCEL_URL=

# =====================================================
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
# 3. NEVER commit the .env file (it is in .gitignore)
# =====================================================
